<?xml version="1.0" encoding="UTF-8"?>
<!--
  finddlg.ui -- the Find, Replace, and Go To Line dialogs: three plain
  GtkWindow toplevels (not GtkApplicationWindow -- these are secondary
  dialogs, transient-for the main window, which is set at runtime since
  it doesn't exist until window.ui/ensure_main_window has run -- see
  finddlg.asm's ensure_finddlg_loaded/setup_dialog_shell). Modality and
  the close-request "hide instead of destroy" behavior are also runtime
  concerns (signals), not static XML properties, matching this project's
  choice not to use GtkBuilder's <signal>/connect-signals auto-wiring --
  see finddlg.asm for every actual g_signal_connect_data call.

  "_" marks each button's Alt-accessible mnemonic (use-underline, same
  effect as the old gtk_button_new_with_mnemonic call sites).
-->
<interface>
  <object class="GtkWindow" id="find_dialog">
    <property name="title">Find</property>
    <property name="resizable">false</property>
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">8</property>
        <property name="margin-start">10</property>
        <property name="margin-end">10</property>
        <property name="margin-top">10</property>
        <property name="margin-bottom">10</property>
        <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="spacing">8</property>
            <child>
              <object class="GtkLabel">
                <property name="label">Find what:</property>
              </object>
            </child>
            <child>
              <object class="GtkEntry" id="find_entry">
                <property name="hexpand">true</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="spacing">8</property>
            <child>
              <object class="GtkButton" id="find_next_btn">
                <property name="label">_Find Next</property>
                <property name="use-underline">true</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="find_cancel_btn">
                <property name="label">_Cancel</property>
                <property name="use-underline">true</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>

  <object class="GtkWindow" id="replace_dialog">
    <property name="title">Replace</property>
    <property name="resizable">false</property>
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">8</property>
        <property name="margin-start">10</property>
        <property name="margin-end">10</property>
        <property name="margin-top">10</property>
        <property name="margin-bottom">10</property>
        <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="spacing">8</property>
            <child>
              <object class="GtkLabel">
                <property name="label">Find what:</property>
              </object>
            </child>
            <child>
              <object class="GtkEntry" id="replace_find_entry">
                <property name="hexpand">true</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="spacing">8</property>
            <child>
              <object class="GtkLabel">
                <property name="label">Replace with:</property>
              </object>
            </child>
            <child>
              <object class="GtkEntry" id="replace_with_entry">
                <property name="hexpand">true</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="spacing">8</property>
            <child>
              <object class="GtkButton" id="replace_find_next_btn">
                <property name="label">_Find Next</property>
                <property name="use-underline">true</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="replace_btn">
                <property name="label">_Replace</property>
                <property name="use-underline">true</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="replace_all_btn">
                <property name="label">Replace _All</property>
                <property name="use-underline">true</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="replace_cancel_btn">
                <property name="label">_Cancel</property>
                <property name="use-underline">true</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>

  <object class="GtkWindow" id="goto_dialog">
    <property name="title">Go To Line</property>
    <property name="resizable">false</property>
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">8</property>
        <property name="margin-start">10</property>
        <property name="margin-end">10</property>
        <property name="margin-top">10</property>
        <property name="margin-bottom">10</property>
        <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="spacing">8</property>
            <child>
              <object class="GtkLabel">
                <property name="label">Line number:</property>
              </object>
            </child>
            <child>
              <!-- min=1 (line numbers are 1-based), max=1,000,000 (a
                   generous ceiling, not tied to actual document length),
                   step=1 (up/down steppers move by whole lines) -- same
                   three values the old gtk_spin_button_new_with_range
                   call passed directly. -->
              <object class="GtkSpinButton" id="goto_spin">
                <property name="hexpand">true</property>
                <property name="adjustment">
                  <object class="GtkAdjustment">
                    <property name="lower">1</property>
                    <property name="upper">1000000</property>
                    <property name="step-increment">1</property>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="spacing">8</property>
            <child>
              <object class="GtkButton" id="goto_ok_btn">
                <property name="label">_OK</property>
                <property name="use-underline">true</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="goto_cancel_btn">
                <property name="label">_Cancel</property>
                <property name="use-underline">true</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
