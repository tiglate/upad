msgstr "Ряд %d, Стб %d"

#: src/unsaved.asm:55
msgid "Save changes?"
msgstr "Зберегти зміни?"

#: src/unsaved.asm:56
msgid "This document has unsaved changes. If you close without saving, those changes will be lost."
msgstr "У цьому документі є незбережені зміни. Якщо ви закриєте його без збереження, ці зміни буде втрачено."

#: src/unsaved.asm:66
msgid "_Discard"
msgstr "_Не зберігати"
