msgid "Light _Mode"
msgstr "Mod _luminos"

#: src/printing.asm:51
msgid "UnbloatedPad Document"
msgstr "Document UnbloatedPad"

#: src/printing.asm:57
msgid "Could not print"
msgstr "Imprimarea nu a putut fi efectuată"

#: src/printing.asm:58
msgid "The print job could not be completed. Check the printer connection and try again."
msgstr "Sarcina de imprimare nu a putut fi finalizată. Verificați conexiunea imprimantei și încercați din nou."

#: src/statusbar.asm:20
msgid "Ln %d, Col %d"
msgstr "Lin %d, Col %d"

#: src/unsaved.asm:55
msgid "Save changes?"
msgstr "Salvați modificările?"

#: src/unsaved.asm:56
msgid "This document has unsaved changes. If you close without saving, those changes will be lost."
msgstr "Acest document are modificări nesalvate. Dacă îl închideți fără să salvați, aceste modificări vor fi pierdute."

