#: src/about.asm:33
msgid "A pure x86-64 assembly recreation of classic Notepad for Linux, built directly on the GTK4 and libadwaita C ABI (no C glue code). Created by Tiglate Pileser III (tiglate) with AI assistance."
msgstr "Čista rekreacija klasičnog Bloka za pisanje za Linux napisana u asembleru x86-64, izgrađena izravno na C ABI-ju GTK4 i libadwaite (bez pomoćnog C koda). Izradio Tiglate Pileser III (tiglate) uz pomoć umjetne inteligencije."

#: src/encoding.asm:85
msgid "Save in original encoding?"
msgstr "Spremiti u izvornom kodiranju?"

#: src/encoding.asm:86
msgid "This file wasn't opened as UTF-8 text. Choose whether to save it back in its original encoding, or convert the document to UTF-8."
msgstr "Ova datoteka nije otvorena kao UTF-8 tekst. Odaberite želite li je spremiti natrag u izvornom kodiranju ili pretvoriti dokument u UTF-8."

#: src/encoding.asm:95
msgid "_Keep Original Encoding"
msgstr "_Zadrži izvorno kodiranje"

#: src/encoding.asm:97
msgid "_Convert to UTF-8"
msgstr "_Pretvori u UTF-8"

#: src/encoding.asm:99 src/fileio.asm:58
msgid "Could not open file"
msgstr "Datoteku nije moguće otvoriti"

#: src/encoding.asm:100
msgid "This file's contents don't look like valid UTF-8 or UTF-16 text, and uchardet couldn't identify (or guessed wrong about) whatever legacy 8-bit encoding it might be."
msgstr "Sadržaj ove datoteke ne izgleda kao valjan UTF-8 ili UTF-16 tekst, a uchardet nije uspio prepoznati (ili je pogrešno pretpostavio) o kojem se starijem 8-bitnom kodiranju možda radi."

#: src/encoding.asm:101 src/fileio.asm:60
msgid "Could not save file"
msgstr "Datoteku nije moguće spremiti"

#: src/encoding.asm:102
msgid "This document contains characters that can't be converted back to the encoding it was originally opened with. Nothing was saved -- try again and choose to convert to UTF-8 instead."
msgstr "Ovaj dokument sadrži znakove koji se ne mogu pretvoriti natrag u kodiranje s kojim je izvorno otvoren. Ništa nije spremljeno -- pokušajte ponovno i odaberite pretvorbu u UTF-8."

#: src/fileio.asm:52
msgid "Open File"
msgstr "Otvori datoteku"

#: src/fileio.asm:53
msgid "Save File As"
msgstr "Spremi datoteku kao"

#: src/fileio.asm:54
