#: src/unsaved.asm:55
msgid "Save changes?"
msgstr "Spremiti promjene?"

#: src/unsaved.asm:56
msgid "This document has unsaved changes. If you close without saving, those changes will be lost."
msgstr "Ovaj dokument sadrži nespremljene promjene. Ako ga zatvorite bez spremanja, te će promjene biti izgubljene."

