#: src/about.asm:33
msgid "A pure x86-64 assembly recreation of classic Notepad for Linux, built directly on the GTK4 and libadwaita C ABI (no C glue code). Created by Tiglate Pileser III (tiglate) with AI assistance."
msgstr "En ren x86-64-assembly-gjenskaping av klassisk Notisblokk for Linux, bygget direkte på C-ABI-et til GTK4 og libadwaita (ingen C-limkode). Laget av Tiglate Pileser III (tiglate) med hjelp fra KI."

#: src/encoding.asm:85
msgid "Save in original encoding?"
msgstr "Lagre i opprinnelig tegnkoding?"

#: src/encoding.asm:86
msgid "This file wasn't opened as UTF-8 text. Choose whether to save it back in its original encoding, or convert the document to UTF-8."
msgstr "Denne filen ble ikke åpnet som UTF-8-tekst. Velg om du vil lagre den tilbake i den opprinnelige tegnkodingen, eller konvertere dokumentet til UTF-8."

#: src/encoding.asm:95
msgid "_Keep Original Encoding"
msgstr "_Behold opprinnelig tegnkoding"

#: src/encoding.asm:97
msgid "_Convert to UTF-8"
msgstr "_Konverter til UTF-8"

#: src/encoding.asm:99 src/fileio.asm:58
msgid "Could not open file"
msgstr "Kunne ikke åpne filen"

#: src/encoding.asm:100
msgid "This file's contents don't look like valid UTF-8 or UTF-16 text, and uchardet couldn't identify (or guessed wrong about) whatever legacy 8-bit encoding it might be."
msgstr "Innholdet i denne filen ser ikke ut som gyldig UTF-8- eller UTF-16-tekst, og uchardet klarte ikke å identifisere (eller gjettet feil på) hvilken eldre 8-bits tegnkoding det kan være."

#: src/encoding.asm:101 src/fileio.asm:60
msgid "Could not save file"
msgstr "Kunne ikke lagre filen"

#: src/encoding.asm:102
msgid "This document contains characters that can't be converted back to the encoding it was originally opened with. Nothing was saved -- try again and choose to convert to UTF-8 instead."
msgstr "Dette dokumentet inneholder tegn som ikke kan konverteres tilbake til tegnkodingen det opprinnelig ble åpnet med. Ingenting ble lagret -- prøv igjen og velg å konvertere til UTF-8 i stedet."

