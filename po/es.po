#: src/printing.asm:57
msgid "Could not print"
msgstr "No se pudo imprimir"

#: src/printing.asm:58
msgid "The print job could not be completed. Check the printer connection and try again."
msgstr "No se pudo completar el trabajo de impresión. Compruebe la conexión de la impresora e inténtelo de nuevo."

#: src/statusbar.asm:20
msgid "Ln %d, Col %d"
msgstr "Lín %d, Col %d"

#: src/unsaved.asm:55
msgid "Save changes?"
msgstr "¿Guardar los cambios?"

#: src/unsaved.asm:56
msgid "This document has unsaved changes. If you close without saving, those changes will be lost."
msgstr "Este documento tiene cambios sin guardar. Si cierra sin guardar, esos cambios se perderán."

