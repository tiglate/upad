#: src/fileio.asm:53
msgid "Save File As"
msgstr "Guardar archivo como"

#: src/fileio.asm:54
msgid "Untitled"
msgstr "Sin título"

#: src/fileio.asm:59
msgid "Could not read file"
msgstr "No se pudo leer el archivo"

