#: src/about.asm:33
msgid "A pure x86-64 assembly recreation of classic Notepad for Linux, built directly on the GTK4 and libadwaita C ABI (no C glue code). Created by Tiglate Pileser III (tiglate) with AI assistance."
msgstr "Una recreación del clásico Bloc de notas para Linux, escrita íntegramente en ensamblador x86-64 puro, sobre la ABI en C de GTK4 y libadwaita (sin código auxiliar en C). Creado por Tiglate Pileser III (tiglate) con asistencia de IA."

#: src/encoding.asm:85
msgid "Save in original encoding?"
msgstr "¿Guardar en la codificación original?"

#: src/encoding.asm:86
msgid "This file wasn't opened as UTF-8 text. Choose whether to save it back in its original encoding, or convert the document to UTF-8."
msgstr "Este archivo no se abrió como texto UTF-8. Elija si desea guardarlo de nuevo en su codificación original o convertir el documento a UTF-8."

#: src/encoding.asm:95
msgid "_Keep Original Encoding"
msgstr "_Mantener codificación original"

#: src/encoding.asm:97
msgid "_Convert to UTF-8"
msgstr "_Convertir a UTF-8"

#: src/encoding.asm:99 src/fileio.asm:58
msgid "Could not open file"
msgstr "No se pudo abrir el archivo"

#: src/encoding.asm:100
msgid "This file's contents don't look like valid UTF-8 or UTF-16 text, and uchardet couldn't identify (or guessed wrong about) whatever legacy 8-bit encoding it might be."
msgstr "El contenido de este archivo no parece texto UTF-8 o UTF-16 válido, y uchardet no pudo identificar (o adivinó mal) la codificación heredada de 8 bits que pudiera ser."

#: src/encoding.asm:101 src/fileio.asm:60
msgid "Could not save file"
msgstr "No se pudo guardar el archivo"

#: src/encoding.asm:102
msgid "This document contains characters that can't be converted back to the encoding it was originally opened with. Nothing was saved -- try again and choose to convert to UTF-8 instead."
msgstr "Este documento contiene caracteres que no se pueden convertir de nuevo a la codificación con la que se abrió originalmente. No se guardó nada -- inténtelo de nuevo y elija convertir a UTF-8."

#: src/fileio.asm:52
msgid "Open File"
