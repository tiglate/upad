#: src/printing.asm:57
msgid "Could not print"
msgstr "Impossibile stampare"

#: src/printing.asm:58
msgid "The print job could not be completed. Check the printer connection and try again."
msgstr "Non è stato possibile completare il lavoro di stampa. Controlla il collegamento della stampante e riprova."

#: src/statusbar.asm:20
msgid "Ln %d, Col %d"
msgstr "Rig %d, Col %d"

#: src/unsaved.asm:55
msgid "Save changes?"
msgstr "Salvare le modifiche?"

#: src/unsaved.asm:56
msgid "This document has unsaved changes. If you close without saving, those changes will be lost."
msgstr "Questo documento contiene modifiche non salvate. Se chiudi senza salvare, tali modifiche andranno perse."

