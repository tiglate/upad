#: src/printing.asm:57
msgid "Could not print"
msgstr "Det gick inte att skriva ut"

#: src/printing.asm:58
msgid "The print job could not be completed. Check the printer connection and try again."
msgstr "Utskriftsjobbet kunde inte slutföras. Kontrollera skrivarens anslutning och försök igen."

#: src/statusbar.asm:20
