#: src/about.asm:33
msgid "A pure x86-64 assembly recreation of classic Notepad for Linux, built directly on the GTK4 and libadwaita C ABI (no C glue code). Created by Tiglate Pileser III (tiglate) with AI assistance."
msgstr "Hrein endursköpun á hinu klassíska Notepad fyrir Linux, skrifuð algjörlega í x86-64 smalamáli (assembly), byggð beint ofan á C-ABI GTK4 og libadwaita (enginn C-tengikóði). Búið til af Tiglate Pileser III (tiglate) með aðstoð gervigreindar."

#: src/encoding.asm:85
msgid "Save in original encoding?"
msgstr "Vista í upprunalegri stafatöflu?"

#: src/encoding.asm:86
msgid "This file wasn't opened as UTF-8 text. Choose whether to save it back in its original encoding, or convert the document to UTF-8."
msgstr "Þessi skrá var ekki opnuð sem UTF-8 texti. Veldu hvort þú vilt vista hana aftur í upprunalegri stafatöflu eða breyta skjalinu í UTF-8."

#: src/encoding.asm:95
msgid "_Keep Original Encoding"
msgstr "_Halda upprunalegri stafatöflu"

#: src/encoding.asm:97
msgid "_Convert to UTF-8"
msgstr "_Breyta í UTF-8"

#: src/encoding.asm:99 src/fileio.asm:58
msgid "Could not open file"
msgstr "Ekki tókst að opna skrá"

#: src/encoding.asm:100
msgid "This file's contents don't look like valid UTF-8 or UTF-16 text, and uchardet couldn't identify (or guessed wrong about) whatever legacy 8-bit encoding it might be."
msgstr "Innihald þessarar skrár lítur ekki út fyrir að vera gilt UTF-8 eða UTF-16 letur, og uchardet gat hvorki greint (né giskaði rétt á) hvaða eldri 8-bita stafatöflu um væri að ræða."

#: src/encoding.asm:101 src/fileio.asm:60
msgid "Could not save file"
msgstr "Ekki tókst að vista skrá"

#: src/encoding.asm:102
msgid "This document contains characters that can't be converted back to the encoding it was originally opened with. Nothing was saved -- try again and choose to convert to UTF-8 instead."
msgstr "Þetta skjal inniheldur stafi sem ekki er hægt að breyta aftur í þá stafatöflu sem það var upphaflega opnað með. Ekkert var vistað -- reyndu aftur og veldu að breyta í UTF-8 í staðinn."

